            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"persona\": {\n    \"nombre\": \"Juan\",\n    \"apellido_paterno\": \"Pérez\",\n    \"apellido_materno\": \"García\",\n    \"correo\": \"juan.perez@email.com\",\n    \"telefono\": \"987654321\"\n  },\n  \"contrasenia\": \"Password123!\",\n  \"rolId\": 2,\n  \"estado\": \"ACTIVO\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"access_token\", jsonData.accessToken);",
                  "    pm.environment.set(\"refresh_token\", jsonData.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"juan.perez@email.com\",\n  \"contrasenia\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{refresh_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            }
          }
        }
